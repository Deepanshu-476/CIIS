{
  "name": "ciisnetwork",
  "productName": "CIIS Network",
  "private": true,
  "version": "1.0.1",
  "description": "CIIS Network desktop application.",
  "author": "CIIS Network",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:preview": "npm run build && electron .",
    "build": "vite build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@date-io/date-fns": "^2.17.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^5.18.0",
    "@mui/joy": "5.0.0-beta.52",
    "@mui/lab": "^5.0.0-alpha.170",
    "@mui/material": "^5.18.0",
    "@mui/system": "^5.18.0",
    "@mui/utils": "^5.16.14",
    "@mui/x-data-grid": "^6.20.4",
    "@mui/x-date-pickers": "^6.20.2",
    "@tailwindcss/vite": "^4.1.16",
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "date-fns": "^2.30.0",
    "dayjs": "^1.11.19",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.2",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.561.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-content": "^0.0.1",
    "react-countup": "^6.5.3",
    "react-dom": "^18.2.0",
    "react-google-recaptcha": "^3.1.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.7.0",
    "react-select": "^5.10.2",
    "react-toastify": "^11.0.5",
    "react-window": "^2.2.7",
    "recharts": "^3.1.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sweetalert2": "^11.26.17",
    "sweetalert2-react-content": "^5.1.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^31.7.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.16",
    "vite": "^7.0.0",
    "wait-on": "^7.2.0"
  }
}
